# SERVER CONFIG
PORT=3000
NODE_ENV=development

# DATABASE CONFIG
# Replace with your MongoDB URL
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/tuk-tuk-tracker

# SECURITY CONFIG
JWT_SECRET=your_super_secret_jwt_key_change_this
# How long the token is valid (e.g., 7d, 24h)
JWT_EXPIRES_IN=7d

# CORS CONFIG
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173